# ========== REQUERIDOS (para guardar datos y auth) ==========
# Supabase
VITE_SUPABASE_URL=tu-supabase-url
VITE_SUPABASE_ANON_KEY=tu-supabase-key
SUPABASE_SERVICE_ROLE_KEY=tu-supabase-service-role-key

# ========== IA (motor principal: Google Gemini) ==========
# Gemini: usado por tutor, Research Center, detección de conceptos
VITE_GOOGLE_GEMINI_API_KEY=tu-gemini-key

# ========== OPCIONALES ==========
# Imágenes educativas: por defecto Pollinations.ai (gratuito, sin key)
# Si quieres DALL·E: descomenta y configura
# VITE_OPENAI_API_KEY=tu-openai-key

# Voces Lina (es) y Rachelle (en) – Azure Speech (recomendado para la Profe Lina)
VITE_AZURE_SPEECH_KEY=tu-azure-speech-key
VITE_AZURE_REGION=tu-region
# Opcional: ElevenLabs como respaldo
# VITE_ELEVENLABS_API_KEY=tu-elevenlabs-key

# Google Classroom (ver docs/INTEGRATIONS_STATUS.md)
VITE_GOOGLE_CLIENT_ID=tu-client-id.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_SECRET=GOCSPX-tu-client-secret
VITE_GOOGLE_REDIRECT_URI=http://localhost:5173/api/google/callback

# Cron / sync (si usas Vercel cron)
CRON_SECRET=genera-un-string-aleatorio-seguro

# Monitoreo de errores en producción (Sentry). Opcional.
# Si no se configura, la app funciona igual; no se envían eventos.
# VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

// Textos de saludo pregrabados para Lina (se usarán con TTS dinámico)
export const LINA_GREETING_TEXTS = [
    "¡Hola! Soy la Profe Lina. ¿Listo para aprender matemáticas?",
    "¡Woooow! ¡Qué alegría verte! Vamos a resolver esto juntos.",
    "¡Hola campeón! ¿Qué ejercicio vamos a conquistar hoy?",
    "¡Esa es la actitud! Hoy vamos a brillar con las matemáticas."
];

import { freeVoiceService, speak as freeSpeak } from './freeVoiceService';

// Main TTS Service Class
class TTSService {
    private static instance: TTSService;
    private useFreeService: boolean = true; // Default to free service
    private isInitialized: boolean = false;

    static getInstance(): TTSService {
        if (!TTSService.instance) {
            TTSService.instance = new TTSService();
        }
        return TTSService.instance;
    }

    async initialize(): Promise<void> {
        if (this.isInitialized) return;

        try {
            // Initialize free voice service
            await freeVoiceService.initialize();
            this.isInitialized = true;
            console.log('✅ TTS Service initialized with free high-quality voices');
        } catch (error) {
            console.error('❌ Failed to initialize TTS service:', error);
            throw error;
        }
    }

    // Main speak function - uses free service by default
    async speak(text: string, tutor: 'lina' | 'rachelle' | 'spark' | 'chronos' | 'male' | 'female' | 'jorge' | 'gonzalo' | 'diego' = 'lina', options?: SpeechOptions & { cancelExisting?: boolean }): Promise<void> {
        await this.initialize();

        try {
            // Use free service (high quality, no cost)
            if (this.useFreeService) {
                await freeSpeak(text, tutor, options);
                return;
            }

            // Fallback to Edge TTS (premium, costs money)
            await this.speakWithEdgeTTS(text, tutor, options);

        } catch (error) {
            console.error(`❌ Speech failed for ${tutor}:`, error);
            
            // Try fallback if primary method fails
            if (this.useFreeService) {
                console.log('🔄 Falling back to Edge TTS...');
                this.useFreeService = false;
                await this.speakWithEdgeTTS(text, tutor, options);
                this.useFreeService = true; // Reset for next time
            } else {
                console.log('🔄 Falling back to free service...');
                this.useFreeService = true;
                await freeSpeak(text, tutor, options);
                this.useFreeService = false; // Reset for next time
            }
        }
    }

    // Legacy Edge TTS implementation (kept for fallback)
    private async speakWithEdgeTTS(text: string, tutor: 'lina' | 'rachelle' | 'spark' | 'chronos' | 'male' | 'female' | 'jorge' | 'gonzalo' | 'diego', options?: SpeechOptions & { cancelExisting?: boolean }): Promise<void> {
        const config = EDGE_VOICES[tutor];
        const utterance = new SpeechSynthesisUtterance(text);
        
        // Configure voice
        utterance.rate = options?.rate !== undefined ? (config.rate + (options.rate / 100)) : config.rate;
        utterance.pitch = options?.pitch !== undefined ? (config.pitch + (options.pitch / 100)) : config.pitch;
        utterance.volume = 1.0;

        // Find best voice
        const voices = window.speechSynthesis.getVoices();
        const selectedVoice = this.findBestVoice(voices, config);
        
        if (selectedVoice) {
            utterance.voice = selectedVoice;
        }

        // Add dynamic variation for expressiveness
        this.addExpressiveness(utterance, tutor, config);

        utterance.onstart = () => {
            window.dispatchEvent(new CustomEvent('nova-demo-voice', { detail: { voice: tutor } }));
        };

        utterance.onend = () => {
            window.dispatchEvent(new CustomEvent('nova-demo-voice-end', { detail: { voice: tutor } }));
        };

        utterance.onerror = () => {
            window.dispatchEvent(new CustomEvent('nova-demo-voice-end', { detail: { voice: tutor } }));
        };

        window.speechSynthesis.speak(utterance);
    }

    private findBestVoice(voices: SpeechSynthesisVoice[], config: EdgeVoiceConfig): SpeechSynthesisVoice | null {
        // 1. Prioritize EXACT Jorge from Mexico
        const jorgeMX = voices.find(v =>
            v.name.toLowerCase().includes('jorge') &&
            (v.lang.toLowerCase().includes('mx') || v.name.toLowerCase().includes('mexico'))
        );
        if (jorgeMX) return jorgeMX;

        // 2. Try match by name and Mexico broadly
        const nameMatch = voices.find(v =>
            v.name.toLowerCase().includes(config.name.toLowerCase()) &&
            !v.lang.toLowerCase().includes('es-es')
        );
        if (nameMatch) return nameMatch;

        // 3. Alternative Latin names, excluding SPAIN
        if (config.altNames) {
            for (const alt of config.altNames) {
                const altMatch = voices.find(v =>
                    v.name.toLowerCase().includes(alt.toLowerCase()) &&
                    !v.lang.toLowerCase().includes('es-es')
                );
                if (altMatch) return altMatch;
            }
        }

        // 4. Force ANY Mexican/Latin voice of the correct gender
        const latinoVoices = voices.filter(v => v.lang.startsWith('es') && !v.lang.toLowerCase().includes('es-es'));
        if (config.gender) {
            const genderMatch = latinoVoices.find(v =>
                v.name.toLowerCase().includes(config.gender === 'male' ? 'male' : 'female') ||
                v.name.toLowerCase().includes(config.gender === 'male' ? 'hombre' : 'mujer') ||
                v.name.toLowerCase().includes(config.gender === 'male' ? 'julio' : 'dalia')
            );
            if (genderMatch) return genderMatch;
        }

        return latinoVoices[0] || null;
    }

    private addExpressiveness(utterance: SpeechSynthesisUtterance, tutor: 'lina' | 'rachelle' | 'spark' | 'chronos' | 'male' | 'female' | 'jorge' | 'gonzalo' | 'diego', config: EdgeVoiceConfig): void {
        // Add dynamic pitch and rate variation for Lina and Rachelle to make them more expressive
        if (tutor === 'lina') {
            const basePitch = utterance.pitch;
            const baseRate = utterance.rate;
            
            // Dynamic pitch variation for expressiveness
            const pitchVariation = (Math.sin(Date.now() * 0.001) * 0.1) + (Math.random() * 0.05);
            utterance.pitch = basePitch + pitchVariation;
            
            // Dynamic rate variation for energy
            const rateVariation = (Math.sin(Date.now() * 0.0008) * 0.08) + (Math.random() * 0.03);
            utterance.rate = baseRate + rateVariation;
        } else if (tutor === 'rachelle') {
            const basePitch = utterance.pitch;
            const baseRate = utterance.rate;
            
            // Dynamic pitch variation for expressiveness (subtler for English)
            const pitchVariation = (Math.sin(Date.now() * 0.0008) * 0.06) + (Math.random() * 0.03);
            utterance.pitch = basePitch + pitchVariation;
            
            // Dynamic rate variation for natural flow
            const rateVariation = (Math.sin(Date.now() * 0.0006) * 0.05) + (Math.random() * 0.02);
            utterance.rate = baseRate + rateVariation;
                utterance.rate = options?.rate !== undefined ? (config.rate + (options.rate / 100)) : config.rate;
                utterance.pitch = options?.pitch ?? config.pitch;
            }
            utterance.volume = 1.0;

            utterance.onstart = () => {
                window.dispatchEvent(new CustomEvent('nova-demo-voice', { detail: { voice: tutor } }));
            };

            utterance.onend = () => {
                this.currentUtterance = null;
                window.dispatchEvent(new CustomEvent('nova-demo-voice-end', { detail: { voice: tutor } }));
                resolve();
            };

            utterance.onerror = () => {
                this.currentUtterance = null;
                window.dispatchEvent(new CustomEvent('nova-demo-voice-end', { detail: { voice: tutor } }));
                resolve();
            };

            this.currentUtterance = utterance;
            this.synth.speak(utterance);
        });
    }

    stop() {
        if (this.synth) {
            this.synth.cancel();
            this.currentUtterance = null;
        }
    }
}

export const edgeTTS = new EdgeTTSService();

export async function generateSpeech(text: string, voiceId?: string, options?: SpeechOptions & { cancelExisting?: boolean }): Promise<void> {
    let tutor: 'lina' | 'rachelle' | 'spark' | 'chronos' | 'male' | 'female' = 'lina';
    if (voiceId?.includes('rachelle')) tutor = 'rachelle';
    else if (voiceId?.includes('spark')) tutor = 'spark';
    else if (voiceId?.includes('chronos')) tutor = 'chronos';
    else if (voiceId?.includes('male')) tutor = 'male';
    else if (voiceId?.includes('female')) tutor = 'female';
    return edgeTTS.speak(text, tutor, options);
}

export const LINA_GREETING_AUDIO_TEXTS = LINA_GREETING_TEXTS;
